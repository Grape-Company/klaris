ENVIRONMENT=production
ENABLE_DOCS=false
LOG_LEVEL=INFO

POSTGRES_USER=deepwoken
POSTGRES_PASSWORD=replace-with-a-long-random-password
POSTGRES_DB=deepwoken

ADMIN_API_KEY=replace-with-a-long-random-admin-token

MEDIAWIKI_API_URL=https://deepwoken.fandom.com/api.php
CRAWLER_USER_AGENT=DeepwokenRAGBot/0.1
CRAWLER_DELAY_SECONDS=0.5
CRAWLER_MAX_RETRIES=3
CRAWLER_TIMEOUT_SECONDS=30

OPENAI_API_KEY=replace-with-provider-api-key
OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1
EMBEDDING_MODEL=nvidia/llama-nemotron-embed-1b-v2
EMBEDDING_DIMENSIONS=1536
LLM_MODEL=openai/gpt-oss-20b
LLM_TEMPERATURE=1
RAG_TOP_K=8
RAG_MAX_TOKENS=4096
RAG_REQUEST_TIMEOUT_SECONDS=30
RAG_MAX_ANSWER_CHARS=1800

DISCORD_BOT_TOKEN=replace-with-discord-bot-token
DISCORD_GUILD_ID=
RAG_API_URL=http://app:8000
BOT_REQUEST_TIMEOUT_SECONDS=30
BOT_RATE_LIMIT_COUNT=5
BOT_RATE_LIMIT_WINDOW_SECONDS=60
BOT_DEFAULT_TOP_K=8
